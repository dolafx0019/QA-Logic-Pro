# =============================================================
# QA-Logic Pro — Root .gitignore
# =============================================================

# ── Secrets & Environment ─────────────────────────────────────
.env
.env.local
.env.*.local
# Allow the example template to be committed
!.env.example

# ── Python / Backend ─────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python

# Virtual environments
venv/
.venv/
env/
ENV/

# Pytest
.pytest_cache/
.coverage
htmlcov/
coverage.xml
*.cover

# Database files
*.db
*.sqlite
*.sqlite3

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg
wheels/

# Temporary / debug scripts
test_gemini.py

# ── Node / Frontend ───────────────────────────────────────────
node_modules/
dist/
.vite/
*.local

# Build outputs
qa_logic_frontend/dist/

# Test outputs (Playwright, Jest, etc.)
test-results/
playwright-report/
coverage/

# Misc JS artifacts
*.tsbuildinfo
test.css

# ── IDEs & OS ─────────────────────────────────────────────────
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
.DS_Store
Thumbs.db
desktop.ini

# ── Logs ──────────────────────────────────────────────────────
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
